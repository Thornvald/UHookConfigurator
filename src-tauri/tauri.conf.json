{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UHook Configurator",
  "version": "0.1.1",
  "identifier": "com.uhook.configurator",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "bun run --cwd frontend dev",
    "beforeBuildCommand": "bun run --cwd frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "UHook Configurator",
        "width": 680,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
